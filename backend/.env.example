# The app auto-detects which provider to use based on which key is set
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
GEMINI_API_KEY=
